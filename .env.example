# --- Backend ---
DATABASE_URL=postgresql://trading:trading@localhost:5432/ai_trading
CONFIRM_TTL_SECONDS=180

# Auth: disabled (X-User-Id multi-tenant demo) | clerk
AUTH_MODE=disabled
DEMO_USER_ID=demo
# CLERK_ISSUER=https://xxx.clerk.accounts.dev
# CLERK_JWKS_URL=https://xxx.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=

# Broker: sim (default, Canada-safe demo) | ibkr | alpaca
BROKER_BACKEND=sim

# --- PaperSim: no keys needed ---

# --- IBKR paper (local Gateway; not for Render free tier) ---
# IB Gateway Paper mode → port 4002; TWS paper → 7497
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
# Optional: pip install ib_async

# --- Alpaca (NOT available for Canadian residents) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# LLM: xai (default) | openai | anthropic — empty key falls back to keyword demo
LLM_PROVIDER=xai
LLM_MODEL=
# LLM_MODEL=grok-4-1-fast-non-reasoning
XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_BASE_URL=https://api.x.ai/v1
# OPENAI_API_KEY=
# XAI_API_KEY=

# Risk defaults (policy engine)
DEFAULT_MAX_POSITION_PCT=5.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
DEFAULT_MAX_OPEN_POSITIONS=10
PAPER_ONLY=true

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://hilarious-piroshki-08d173.netlify.app

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
