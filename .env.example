# --- Backend ---
DATABASE_URL=postgresql://trading:trading@localhost:5432/ai_trading
# DATABASE_URL_DISABLED=true
CONFIRM_TTL_SECONDS=180

# Auth: disabled (X-User-Id multi-tenant demo) | clerk
AUTH_MODE=disabled
DEMO_USER_ID=demo
# Production guards — set true on Render to enforce posture
# REQUIRE_CLERK_AUTH=true
# REQUIRE_SIM_BROKER=true
# EXPOSE_OPENAPI_DOCS=false
# PUBLIC_HEALTH_VERBOSE=false

# Clerk (API) — required when AUTH_MODE=clerk
# CLERK_ISSUER=https://xxx.clerk.accounts.dev
# CLERK_JWKS_URL=https://xxx.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=

# Stripe (PR3) — leave empty to disable paid checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PRO_PLUS=
STRIPE_SUCCESS_URL=https://hilarious-piroshki-08d173.netlify.app/?billing=success
STRIPE_CANCEL_URL=https://hilarious-piroshki-08d173.netlify.app/?billing=cancel
# STRIPE_DEV_MODE=true   # NEVER in production
# FREE_CHAT_PER_DAY=25

# Broker: sim (default, Canada-safe demo) | ibkr | alpaca
BROKER_BACKEND=sim

# --- PaperSim: no keys needed ---

# --- IBKR paper (local Gateway; not for Render free tier) ---
# IB Gateway Paper mode → port 4002; TWS paper → 7497
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
# Optional: pip install ib_async

# --- Alpaca (NOT available for Canadian residents) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Market data (not brokers) ---
# FMP = Financial Modeling Prep (preferred for quotes + EOD history)
# FMP_API_KEY=
# FMP_BASE_URL=https://financialmodelingprep.com
# Alpha Vantage — news sentiment + quote/bars fallback (tight free limits)
# ALPHA_VANTAGE_API_KEY=
# Massive.com (Polygon-compatible) — news / prev close fallback
# MASSIVE_API_KEY=
# MASSIVE_BASE_URL=https://api.polygon.io
# Yahoo free chart API is built-in as unofficial backstop (no key)

# --- Plaid (optional bank linking) ---
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# LLM: xai (default) | openai | anthropic — empty key falls back to keyword demo
LLM_PROVIDER=xai
LLM_MODEL=
# LLM_MODEL=grok-4-1-fast-non-reasoning
XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_BASE_URL=https://api.x.ai/v1

# Risk defaults (policy engine)
DEFAULT_MAX_POSITION_PCT=5.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
DEFAULT_MAX_OPEN_POSITIONS=10
PAPER_ONLY=true
# PAPER_ALLOW_OUTSIDE_RTH=true

# Admin (PR4)
# ADMIN_API_KEY=          # X-Admin-Key header; empty disables /admin/*
# GLOBAL_KILL_SWITCH=false
# LLM_BREAKER_FAILURE_THRESHOLD=5
# LLM_BREAKER_WINDOW_SECONDS=60
# LLM_BREAKER_COOLDOWN_SECONDS=120
# LLM_BREAKER_OPEN_MODE=demo

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://hilarious-piroshki-08d173.netlify.app

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk (apps/web) — https://dashboard.clerk.com/
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_APP_URL=http://localhost:3000
